#: templates/legal/privacy.html:26
msgid "Pour maintenir votre session de travail"
msgstr "Para mantener tu sesión de trabajo"

#: templates/legal/privacy.html:27
msgid "Préférences :"
msgstr "Preferencias:"

#: templates/legal/privacy.html:27
msgid "Pour mémoriser vos paramètres d'interface"
msgstr "Para recordar tus configuraciones de interfaz"

#: templates/legal/privacy.html:30
msgid "Publicité — Google AdSense"
msgstr "Publicidad — Google AdSense"

#: templates/legal/privacy.html:31
#, python-format
msgid ""
"Ce site utilise <strong>Google AdSense</strong> (ID: %(adsense_id)s) pour"
" afficher des publicités pertinentes."
msgstr ""
"Este sitio utiliza <strong>Google AdSense</strong> (ID: %(adsense_id)s) "
"para mostrar anuncios relevantes."

#: templates/legal/privacy.html:32
