msgstr ""
"Ofrecer una herramienta PDF en línea potente, intuitiva y respetuosa con "
"tu privacidad."

#: templates/legal/about.html:16
msgid "Caractéristiques principales"
msgstr "Características principales"

#: templates/legal/about.html:26
