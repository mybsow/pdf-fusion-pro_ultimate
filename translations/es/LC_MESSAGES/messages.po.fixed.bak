#: templates/pdf/compress.html:31
msgid "Faible"
msgstr "Bajo"

#: templates/pdf/compress.html:35
msgid "Fort"
msgstr "Alto"

#: templates/pdf/compress.html:37
msgid "Compression plus forte = fichier plus petit, qualité réduite"
msgstr "Compresión más fuerte = archivo más pequeño, calidad reducida"

#: templates/pdf/compress.html:43
msgid "Compresser le PDF"
msgstr "Comprimir PDF"

#: templates/pdf/index.html:3
msgid "Accueil - PDF Fusion Pro – Outils PDF Gratuits"
msgstr "Inicio - PDF Fusion Pro – Herramientas PDF Gratuitas"

#: templates/pdf/index.html:5
#, python-format
msgid ""
"Tous les outils PDF en un seul endroit : fusionner, diviser, tourner, "
"compresser et convertir des fichiers PDF. 100%% gratuit, sécurisé et sans "
"inscription."
msgstr ""
"Todas las herramientas PDF en un solo lugar: fusionar, dividir, girar, "
"comprimir y convertir archivos PDF. 100%% gratis, seguro y sin registro."

#: templates/pdf/index.html:10
msgid "Transformez vos PDFs en toute simplicité"
msgstr "Transforme sus PDFs con facilidad"

#: templates/pdf/index.html:12
#, python-format
msgid ""
"Outil PDF tout-en-un : fusion, division, rotation, compression et "
"conversion. Rapide, sécurisé et 100%%% gratuit."
msgstr ""
"Herramienta PDF todo-en-uno: fusionar, dividir, rotar, comprimir y "
"convertir. Rápido, seguro y 100%%% gratuito."

#: templates/pdf/index.html:13
msgid ""
"Aucune inscription requise – vos fichiers ne quittent jamais votre "
"navigateur."
msgstr "No se requiere registro – sus archivos nunca salen de su navegador."

#: templates/pdf/index.html:23
msgid "Fusionner des fichiers PDF"
msgstr "Fusionar archivos PDF"

#: templates/pdf/index.html:24
msgid "Combine plusieurs PDF en un seul document organisé"
msgstr "Combina varios PDF en un solo documento organizado"

#: templates/pdf/index.html:28
msgid "Fusionner des PDF"
msgstr "Fusionar PDFs"

#: templates/pdf/index.html:31
msgid "Accédez à l'outil de fusion PDF"
msgstr "Acceda a la herramienta de fusión PDF"

#: templates/pdf/index.html:41
msgid "Diviser un fichier PDF"
msgstr "Dividir un archivo PDF"

#: templates/pdf/index.html:42
msgid "Extrayez des pages spécifiques ou divisez par plages"
msgstr "Extraiga páginas específicas o divida por rangos"

#: templates/pdf/index.html:46 templates/pdf/split.html:8
msgid "Diviser un PDF"
msgstr "Dividir un PDF"

#: templates/pdf/index.html:49
msgid "Accédez à l'outil de division PDF"
msgstr "Acceda a la herramienta de división PDF"

#: templates/pdf/index.html:59
msgid "Tourner un fichier PDF"
msgstr "Girar un archivo PDF"

#: templates/pdf/index.html:60
msgid "Faites pivoter des pages spécifiques ou l'ensemble du document"
msgstr "Gire páginas específicas o todo el documento"

#: templates/pdf/index.html:64 templates/pdf/rotate.html:8
msgid "Tourner un PDF"
msgstr "Girar un PDF"

#: templates/pdf/index.html:67
msgid "Accédez à l'outil de rotation PDF"
msgstr "Acceda a la herramienta de rotación PDF"

#: templates/pdf/index.html:77
msgid "Compresser un fichier PDF"
msgstr "Comprimir un archivo PDF"

#: templates/pdf/index.html:78
msgid "Réduisez la taille de vos PDFs sans perte de qualité notable"
msgstr "Reduzca el tamaño de sus PDFs sin pérdida significativa de calidad"

#: templates/pdf/index.html:85
msgid "Accédez à l'outil de compression PDF"
msgstr "Acceda a la herramienta de compresión PDF"

#: templates/pdf/index.html:97
msgid "Convertisseur universel"
msgstr "Convertidor universal"

#: templates/pdf/index.html:98
msgid ""
"Convertissez vos fichiers Word, Excel, PowerPoint et images en PDF et "
"vice-versa"
msgstr ""
"Convierta sus archivos Word, Excel, PowerPoint e imágenes a PDF y "
"viceversa"

#: templates/pdf/index.html:114
msgid "PDF Fusion Pro en chiffres"
msgstr "PDF Fusion Pro en cifras"

#: templates/pdf/index.html:120
msgid "Utilisateurs"
msgstr "Usuarios"

#: templates/pdf/index.html:124
msgid "PDF traités"
msgstr "PDFs procesados"

#: templates/pdf/index.html:128
msgid "Satisfaction"
msgstr "Satisfacción"

#: templates/pdf/index.html:132
msgid "Disponible"
msgstr "Disponible"

#: templates/pdf/index.html:145
#, python-format
msgid "Votre solution PDF tout-en-un, 100%%% gratuite et sécurisée"
msgstr "Su solución PDF todo-en-uno, 100%%% gratis y segura"

#: templates/pdf/index.html:147
msgid ""
"PDF Fusion Pro est la plateforme idéale pour tous vos besoins en "
"manipulation de fichiers PDF. Que vous ayez besoin de <strong>fusionner "
"plusieurs documents</strong>, <strong>diviser un PDF volumineux</strong>,"
" <strong>tourner des pages mal orientées</strong> ou <strong>compresser "
"des fichiers pour les partager</strong>, nos outils sont là pour vous "
"aider."
msgstr ""
"PDF Fusion Pro es la plataforma ideal para todas sus necesidades de "
"manipulación de archivos PDF. Ya sea que necesite <strong>fusionar varios"
" documentos</strong>, <strong>dividir un PDF grande</strong>, "
"<strong>girar páginas mal orientadas</strong> o <strong>comprimir "
"archivos para compartir</strong>, nuestras herramientas están aquí para "
"ayudarle."

#: templates/pdf/index.html:150
msgid "Aucune inscription requise"
msgstr "No se requiere registro"

#: templates/pdf/index.html:151
msgid "Chiffrement SSL et suppression automatique des fichiers"
msgstr "Cifrado SSL y eliminación automática de archivos"

#: templates/pdf/merge.html:3
msgid "Fusionner PDF - PDF Fusion Pro"
msgstr "Fusionar PDFs"

#: templates/pdf/merge.html:4
msgid ""
"Fusionnez plusieurs fichiers PDF en un seul document, facilement et "
"rapidement."
msgstr "Combina varios PDF en un solo documento organizado"

#: templates/pdf/merge.html:8
msgid "Fusionner plusieurs PDF"
msgstr "Fusionar PDFs"

#: templates/pdf/merge.html:9
msgid "Déposez vos fichiers PDF et obtenez un document unique fusionné."
msgstr "Suelta tus archivos PDF y obtén un único documento fusionado."

#: templates/pdf/merge.html:16
msgid "Déposez vos PDF ici"
msgstr "Suelta tus PDF aquí"

#: templates/pdf/merge.html:17
msgid "Glissez-déposez vos fichiers ou cliquez pour parcourir"
msgstr "Arrastra y suelta tus archivos o haz clic para buscar"

#: templates/pdf/merge.html:28
msgid "Fusionner les PDF"
msgstr "Fusionar PDFs"

#: templates/pdf/rotate.html:3
msgid "Tourner PDF - PDF Fusion Pro"
msgstr "PDF Fusion Pro"

#: templates/pdf/rotate.html:4
msgid "Corrigez l'orientation de vos fichiers PDF en quelques clics."
msgstr "Corrige la orientación de tus archivos PDF en unos clics."

#: templates/pdf/rotate.html:9
msgid "Déposez votre fichier PDF et choisissez l'angle de rotation."
msgstr "Suelta tu archivo PDF y elige el ángulo de rotación."

#: templates/pdf/rotate.html:28
msgid "Pages à tourner"
msgstr "Girar"

#: templates/pdf/rotate.html:29 templates/pdf/split.html:29
msgid "Ex: 1,3-5 ou 'all' pour toutes"
msgstr "Ej: 1,3-5 o 'all' para todas"

#: templates/pdf/rotate.html:30
msgid "Format: numéros séparés par des virgules, plages avec tiret"
msgstr "Formato: números separados por comas, rangos con guión"

#: templates/pdf/rotate.html:33
msgid "Angle de rotation"
msgstr "Ángulo de rotación"

#: templates/pdf/rotate.html:49
msgid "Tourner le PDF"
msgstr "Girar PDF"

#: templates/pdf/split.html:3
msgid "Diviser PDF - PDF Fusion Pro"
msgstr "PDF Fusion Pro"

#: templates/pdf/split.html:4
msgid ""
"Divisez vos fichiers PDF en plusieurs documents selon les pages "
"sélectionnées."
msgstr ""
"Divide tus archivos PDF en varios documentos según las páginas "
"seleccionadas."

#: templates/pdf/split.html:9
msgid "Déposez votre fichier PDF et sélectionnez les pages à extraire."
msgstr "Suelta tu archivo PDF y selecciona las páginas a extraer."

#: templates/pdf/split.html:28
msgid "Pages à extraire"
msgstr "Páginas a extraer"

#: templates/pdf/split.html:30
msgid "Format: numéros séparés par des virgules, plages avec tiret. Ex: \"1,3-5\""
msgstr "Formato: números separados por comas, rangos con guión. Ej: \"1,3-5\""

#: templates/pdf/split.html:36
msgid "Diviser le PDF"
msgstr "Dividir PDF"

