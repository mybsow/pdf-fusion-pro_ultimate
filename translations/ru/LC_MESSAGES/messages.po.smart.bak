msgstr "По любым вопросам, касающимся этих условий:"

#: templates/legal/terms.html:60
msgid "Nous contacter via le formulaire"
msgstr "Свяжитесь с нами через форму"

#: templates/pdf/compress.html:3
msgid "Compresser PDF - PDF Fusion Pro"
msgstr "Сжать PDF"

#: templates/pdf/compress.html:4
msgid "Réduisez la taille de vos fichiers PDF tout en conservant la qualité."
msgstr "Уменьшите размер ваших PDF без заметной потери качества"

#: templates/pdf/compress.html:8 templates/pdf/index.html:82
msgid "Compresser un PDF"
msgstr "Сжать PDF"

#: templates/pdf/compress.html:9
msgid "Déposez votre fichier PDF et obtenez une version plus légère."
msgstr "Перетащите ваш PDF-файл и получите более легкую версию."

#: templates/pdf/compress.html:17 templates/pdf/rotate.html:17
#: templates/pdf/split.html:17
