msgid "Fusionner PDF - PDF Fusion Pro"
msgstr "Unisci PDF"

#: templates/pdf/merge.html:4
msgid ""
"Fusionnez plusieurs fichiers PDF en un seul document, facilement et "
"rapidement."
msgstr "Combina più PDF in un unico documento organizzato"

#: templates/pdf/merge.html:8
msgid "Fusionner plusieurs PDF"
msgstr "Unisci PDF"

#: templates/pdf/merge.html:9
msgid "Déposez vos fichiers PDF et obtenez un document unique fusionné."
msgstr "Deposita i tuoi file PDF e ottieni un unico documento unito."

#: templates/pdf/merge.html:16
msgid "Déposez vos PDF ici"
msgstr "Deposita i tuoi PDF qui"

#: templates/pdf/merge.html:17
msgid "Glissez-déposez vos fichiers ou cliquez pour parcourir"
msgstr "Trascina i tuoi file o clicca per sfogliare"

#: templates/pdf/merge.html:28
msgid "Fusionner les PDF"
msgstr "Unisci PDF"

#: templates/pdf/rotate.html:3
msgid "Tourner PDF - PDF Fusion Pro"
msgstr "PDF Fusion Pro"

#: templates/pdf/rotate.html:4
msgid "Corrigez l'orientation de vos fichiers PDF en quelques clics."
msgstr "Correggi l'orientamento dei tuoi file PDF in pochi clic."

#: templates/pdf/rotate.html:9
msgid "Déposez votre fichier PDF et choisissez l'angle de rotation."
msgstr "Deposita il tuo file PDF e scegli l'angolo di rotazione."

#: templates/pdf/rotate.html:28
msgid "Pages à tourner"
msgstr "Ruota"

#: templates/pdf/rotate.html:29 templates/pdf/split.html:29
msgid "Ex: 1,3-5 ou 'all' pour toutes"
msgstr "Es: 1,3-5 o 'all' per tutte"

#: templates/pdf/rotate.html:30
msgid "Format: numéros séparés par des virgules, plages avec tiret"
msgstr "Formato: numeri separati da virgole, intervalli con trattino"

#: templates/pdf/rotate.html:33
msgid "Angle de rotation"
msgstr "Angolo di rotazione"

#: templates/pdf/rotate.html:49
msgid "Tourner le PDF"
msgstr "Ruota PDF"

#: templates/pdf/split.html:3
msgid "Diviser PDF - PDF Fusion Pro"
msgstr "PDF Fusion Pro"

#: templates/pdf/split.html:4
msgid ""
"Divisez vos fichiers PDF en plusieurs documents selon les pages "
"sélectionnées."
msgstr "Dividi i tuoi file PDF in più documenti in base alle pagine selezionate."

#: templates/pdf/split.html:9
msgid "Déposez votre fichier PDF et sélectionnez les pages à extraire."
msgstr "Deposita il tuo file PDF e seleziona le pagine da estrarre."

#: templates/pdf/split.html:28
msgid "Pages à extraire"
msgstr "Pagine da estrarre"

#: templates/pdf/split.html:30
msgid "Format: numéros séparés par des virgules, plages avec tiret. Ex: \"1,3-5\""
msgstr ""
"Formato: numeri separati da virgole, intervalli con trattino. Es: "
"\"1,3-5\""

#: templates/pdf/split.html:36
msgid "Diviser le PDF"
msgstr "Dividi PDF"

